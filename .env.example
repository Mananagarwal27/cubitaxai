# ──────────────────────────────────────────────────────────────────────
# CubitaxAI — Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Docker: copy to .env.docker and use Docker service hostnames.
# ──────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────
# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
# Model to use for chat and Cypher generation
OPENAI_MODEL=gpt-4o

# ── Vector Database (Pinecone) ───────────────────────────────────────
# Pinecone API key — get from https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_key_here
# Name of the Pinecone index to use
PINECONE_INDEX=cubitax-index
# Pinecone environment/region
PINECONE_ENV=us-east-1

# ── Reranker (Cohere) ───────────────────────────────────────────────
# Cohere API key — get from https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key_here

# ── Database ─────────────────────────────────────────────────────────
# Local dev: sqlite+aiosqlite:///./cubitax.db
# Docker:    postgresql://cubitax:cubitax@postgres:5432/cubitax
# Prod:      postgresql://user:pass@host:5432/cubitax
DATABASE_URL=sqlite+aiosqlite:///./cubitax.db

# ── Redis ────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379/0
# Docker:    redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Neo4j ────────────────────────────────────────────────────────────
# Local dev: bolt://localhost:7687
# Docker:    bolt://neo4j:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cubitax_neo4j

# ── ChromaDB ─────────────────────────────────────────────────────────
# Local dev: localhost / 8001
# Docker:    chromadb / 8000
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Auth ─────────────────────────────────────────────────────────────
# JWT signing key — CHANGE IN PRODUCTION (minimum 32 characters)
SECRET_KEY=your_super_secret_jwt_key_minimum_32_chars
ALGORITHM=HS256
# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=CubitaxAI
APP_VERSION=2.0.0
# Set to false in production
DEBUG=true
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Observability ────────────────────────────────────────────────────
# LangSmith key for tracing — get from https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cubitaxai
# OpenTelemetry OTLP endpoint (leave empty for console-only tracing)
OTEL_EXPORTER_ENDPOINT=

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=200/minute

# ── Frontend ─────────────────────────────────────────────────────────
# API URL used by the React frontend
REACT_APP_API_URL=http://localhost:8000
