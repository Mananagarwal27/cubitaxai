# ════════════════════════════════════════════════
# CubitaxAI Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════

# ── REQUIRED: App ────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=your-32-char-minimum-secret-key-here-change-this

# ── REQUIRED: Database ───────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://cubitax:cubitax@postgres:5432/cubitax

# ── REQUIRED: Redis ──────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── REQUIRED: OpenAI ─────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── REQUIRED: Pinecone ───────────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=cubitaxai
PINECONE_ENVIRONMENT=us-east-1

# ── REQUIRED: Cohere ─────────────────────────────
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...

# ── REQUIRED: Neo4j ──────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cubitax_neo4j_password

# ── OPTIONAL: LangSmith Tracing ──────────────────
# Get from: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=cubitaxai

# ── OPTIONAL: Email Alerts ───────────────────────
# For Gmail: enable 2FA, then generate App Password at:
# https://myaccount.google.com/apppasswords
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_USE_TLS=true

# ── OPTIONAL: TRACES Portal (Form 26AS auto-fetch) ──
# Register at: https://developer.tdscpc.gov.in
# Steps: Create account → New Application → OAuth 2.0 credentials
TRACES_CLIENT_ID=
TRACES_CLIENT_SECRET=
TRACES_BASE_URL=https://www.tdscpc.gov.in/app/api

# ── OPTIONAL: GST Portal (GSTR-2B auto-fetch) ───────
# Register at: https://developer.gst.gov.in
# Steps: Login with GST credentials → API Access → Create App
GST_CLIENT_ID=
GST_CLIENT_SECRET=
GST_BASE_URL=https://api.gst.gov.in/commonapi

# ── OPTIONAL: Tally Sync ─────────────────────────────
# Requires TallyPrime with HTTP XML interface enabled
# Set to your local/server IP where Tally is running
TALLY_BRIDGE_URL=http://localhost:9000

# ── OPTIONAL: Zoho Books Sync ────────────────────────
# Get from: https://api-console.zoho.com
# Steps: Create Server-based Application → get Client ID/Secret
# Then run: python scripts/zoho_oauth.py to get refresh token
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── OPTIONAL: Outbound Webhooks ──────────────────────
WEBHOOK_SECRET=generate-a-random-secret-here
ALERT_WEBHOOK_ENABLED=false

# ── File Upload ──────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS (comma-separated) ───────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── App Meta ─────────────────────────────────────────
APP_NAME=CubitaxAI
APP_VERSION=2.0.0

# ── ChromaDB (inside Docker) ────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_CHAT=60/minute
RATE_LIMIT_UPLOAD=10/minute

# ── RAGAS Evaluation (optional) ─────────────────────
RAGAS_EVAL_ENABLED=false
