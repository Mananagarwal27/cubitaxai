# ──────────────────────────────────────────────────────────────────────
# CubitaxAI — Docker Compose Environment Configuration
# Copy this to .env.docker and customize values before running:
#   docker compose --env-file .env.docker up -d --build
# ──────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── Vector Database (Pinecone) ───────────────────────────────────────
# Get your key from https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=cubitax-index
PINECONE_ENVIRONMENT=us-east-1

# ── Reranker (Cohere) ───────────────────────────────────────────────
# Get your key from https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key_here

# ── Database (PostgreSQL inside Docker) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://cubitax:cubitax@postgres:5432/cubitax

# ── Redis (inside Docker) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Neo4j (inside Docker) ───────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cubitax_neo4j

# ── ChromaDB (inside Docker) ────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Auth ─────────────────────────────────────────────────────────────
# CHANGE THIS in production! Minimum 32 characters.
SECRET_KEY=cubitaxai_dev_secret_key_min_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=CubitaxAI
APP_VERSION=2.0.0
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Observability ────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cubitaxai
OTEL_EXPORTER_ENDPOINT=

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=200/minute

# ── Frontend ─────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
